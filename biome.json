{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"overrides": [
		{
			"includes": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
			"linter": {
				"rules": {
					"recommended": true,
					"style": {
						"useConst": "error",
						"noNonNullAssertion": "error"
					},
					"suspicious": {
						"noExplicitAny": "error"
					}
				}
			}
		}
	]
}
