{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"attributePosition": "auto",
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 80,
		"lineEnding": "lf"
	},
	"javascript": {
		"jsxRuntime": "transparent"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": "error",
			"suspicious": "error",
			"style": "error",
			"complexity": "warn",
			"performance": "error",
			"security": "error",
			"nursery": "off"
		}
	},
	"overrides": [
		{
			"includes": ["**/*"],
			"linter": {
				"rules": {
					"correctness": {
						"useQwikValidLexicalScope": "off",
						"noUnresolvedImports": "off",
						"noSolidDestructuredProps": "off",
						"noNodejsModules": "off",
						"noUndeclaredDependencies": "off",
						"useUniqueElementIds": "off"
					},
					"complexity": {
						"noExcessiveLinesPerFunction": {
							"level": "error",
							"options": {
								"maxLines": 4000
							}
						},
						"useMaxParams": {
							"level": "error",
							"options": {
								"max": 10
							}
						},
						"noExcessiveCognitiveComplexity": {
							"level": "error",
							"options": {
								"maxAllowedComplexity": 200
							}
						}
					},
					"security": {
						"noSecrets": "off"
					},
					"style": {
						"noMagicNumbers": "off",
						"useNamingConvention": {
							"level": "error",
							"options": {
								"strictCase": false
							}
						},
						"useFilenamingConvention": {
							"level": "error",
							"options": {
								"strictCase": false
							}
						},
						"noNestedTernary": "off",
						"noJsxLiterals": "off",
						"noParameterAssign": "off"
					},
					"suspicious": {
						"noBitwiseOperators": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.ts", "**/*.js"]
		},
		{
			"includes": ["**/*.tsx", "**/*.jsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noReactSpecificProps": "off"
					}
				}
			}
		},
		{
			"includes": ["jest.config.js", ".dependency-cruiser.js"],
			"linter": {
				"rules": {
					"suspicious": {
						"noReactSpecificProps": "off"
					},
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts", "**/*.test.tsx"],
			"javascript": {
				"globals": [
					"jest",
					"expect",
					"describe",
					"it",
					"beforeAll",
					"afterAll",
					"beforeEach",
					"afterEach"
				]
			},
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		}
	]
}
