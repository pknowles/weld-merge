{
	"name": "meld-auto-merge",
	"displayName": "Meld Auto-Merge",
	"description": "Auto-resolves complex Git merge conflicts using Meld heuristics",
	"version": "0.0.1",
	"publisher": "pknowles",
	"repository": {
		"type": "git",
		"url": "https://github.com/pknowles/meld.git"
	},
	"engines": {
		"vscode": "^1.80.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"customEditors": [
			{
				"viewType": "meld.mergeEditor",
				"displayName": "Meld 3-Way Merge",
				"selector": [
					{
						"filenamePattern": "*"
					}
				],
				"priority": "option"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "meld-auto-merge",
					"title": "Meld",
					"icon": "$(git-merge)"
				}
			]
		},
		"views": {
			"scm": [
				{
					"id": "meldConflictedFiles",
					"name": "Meld Conflicted Files",
					"icon": "$(warning)"
				}
			]
		},
		"menus": {
			"view/item/context": [
				{
					"command": "meld-auto-merge.autoMerge",
					"when": "view == meldConflictedFiles && viewItem == conflictedFile",
					"group": "inline@1"
				},
				{
					"command": "meld-auto-merge.smartAdd",
					"when": "view == meldConflictedFiles && viewItem == conflictedFile",
					"group": "inline@2"
				},
				{
					"command": "meld-auto-merge.checkoutConflicted",
					"when": "view == meldConflictedFiles && (viewItem == conflictedFile || viewItem == resolvedFile)",
					"group": "inline@3"
				},
				{
					"command": "meld-auto-merge.rerereForget",
					"when": "view == meldConflictedFiles && viewItem == conflictedFile",
					"group": "inline@4"
				},
				{
					"command": "meld-auto-merge.openMergeEditor",
					"when": "view == meldConflictedFiles && viewItem == conflictedFile",
					"group": "inline@5"
				},
				{
					"command": "meld-auto-merge.openMeldDiff",
					"when": "view == meldConflictedFiles && viewItem == conflictedFile",
					"group": "inline@6"
				}
			],
			"view/title": [
				{
					"command": "meld-auto-merge.autoMergeAll",
					"when": "view == meldConflictedFiles",
					"group": "navigation@1"
				},
				{
					"command": "meld-auto-merge.refreshConflicted",
					"when": "view == meldConflictedFiles",
					"group": "navigation@2"
				}
			]
		},
		"commands": [
			{
				"command": "meld-auto-merge.autoMerge",
				"title": "Meld: Auto-Merge Current File",
				"icon": "$(merge)"
			},
			{
				"command": "meld-auto-merge.autoMergeAll",
				"title": "Meld: Auto-Merge All Conflicted Files",
				"icon": "$(check-all)"
			},
			{
				"command": "meld-auto-merge.checkoutConflicted",
				"title": "Meld: Checkout Conflicted (-m)",
				"icon": "$(history)"
			},
			{
				"command": "meld-auto-merge.rerereForget",
				"title": "Meld: Rerere Forget File",
				"icon": "$(trash)"
			},
			{
				"command": "meld-auto-merge.smartAdd",
				"title": "Meld: Git Add Resolved",
				"icon": "$(add)"
			},
			{
				"command": "meld-auto-merge.openMergeEditor",
				"title": "Meld: Open 3-Way Merge Editor",
				"icon": "$(git-merge)"
			},
			{
				"command": "meld-auto-merge.openMeldDiff",
				"title": "Meld: Open Custom Merge",
				"icon": "$(split-horizontal)"
			},
			{
				"command": "meld-auto-merge.refreshConflicted",
				"title": "Meld: Refresh Conflicted Files",
				"icon": "$(refresh)"
			}
		],
		"configuration": {
			"title": "Meld",
			"properties": {
				"meld.mergeEditor.debounceDelay": {
					"type": "integer",
					"default": 300,
					"description": "Delay in milliseconds before recomputing diff highlights while typing in the merge editor."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"build:webview": "esbuild ./src/webview/ui/index.tsx --bundle --outfile=./out/webview/index.js --format=iife --platform=browser",
		"compile": "npm run build:webview && tsc -p ./",
		"watch:webview": "esbuild ./src/webview/ui/index.tsx --bundle --outfile=./out/webview/index.js --format=iife --platform=browser --watch",
		"watch": "npm run watch:webview & tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "npx jest",
		"format": "biome format --write .",
		"lint": "biome lint --error-on-warnings --write .",
		"knip": "knip",
		"jscpd": "jscpd src",
		"depcruise": "depcruise src",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@types/jest": "^29.5.12",
		"@types/lodash.debounce": "^4.0.9",
		"@types/node": "18.x",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/vscode": "^1.80.0",
		"dependency-cruiser": "^17.3.8",
		"esbuild": "^0.27.3",
		"husky": "^9.1.7",
		"jest": "^29.7.0",
		"jscpd": "^4.0.8",
		"knip": "^5.85.0",
		"lint-staged": "^16.3.0",
		"monaco-editor": "^0.55.1",
		"ts-jest": "^29.1.2",
		"typescript": "^5.1.3"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"@types/diff": "^7.0.2",
		"diff": "^8.0.3",
		"lodash.debounce": "^4.0.8",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,json}": [
			"biome check --error-on-warnings --write"
		]
	}
}
